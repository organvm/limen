{
  "$defs": {
    "AgentIdentityV1": {
      "additionalProperties": false,
      "properties": {
        "agent": {
          "title": "Agent",
          "type": "string"
        },
        "native_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Native Run Id"
        },
        "provider_identity": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Identity"
        },
        "schema_version": {
          "const": "limen.agent_identity.v1",
          "default": "limen.agent_identity.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "session_id": {
          "title": "Session Id",
          "type": "string"
        },
        "surface": {
          "title": "Surface",
          "type": "string"
        }
      },
      "required": [
        "agent",
        "surface",
        "session_id"
      ],
      "title": "AgentIdentityV1",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Keeper-owned identity and lifecycle for one provider launch attempt.",
  "properties": {
    "adapter": {
      "title": "Adapter",
      "type": "string"
    },
    "attempt_id": {
      "title": "Attempt Id",
      "type": "string"
    },
    "detail": {
      "default": "",
      "title": "Detail",
      "type": "string"
    },
    "executor": {
      "$ref": "#/$defs/AgentIdentityV1"
    },
    "failure_class": {
      "anyOf": [
        {
          "enum": [
            "transient",
            "permanent"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Failure Class"
    },
    "lease_generation": {
      "minimum": 1,
      "title": "Lease Generation",
      "type": "integer"
    },
    "lease_id": {
      "title": "Lease Id",
      "type": "string"
    },
    "provider_run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider Run Id"
    },
    "provider_run_url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider Run Url"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "limen.executor_attempt.v1",
      "default": "limen.executor_attempt.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "enum": [
        "launching",
        "submitted",
        "running",
        "succeeded",
        "failed",
        "blocked"
      ],
      "title": "Status",
      "type": "string"
    },
    "submitted_at": {
      "format": "date-time",
      "title": "Submitted At",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "attempt_id",
    "run_id",
    "lease_id",
    "lease_generation",
    "executor",
    "adapter",
    "status"
  ],
  "title": "ExecutorAttemptV1",
  "type": "object"
}
