LIMEN_TASKS=/limen/tasks.yaml
LIMEN_API_TOKEN=change-me
LIMEN_OWNER_TOKEN=
LIMEN_CLIENT_TOKEN=
LIMEN_CORS_ORIGINS=https://device-streaming-067d747a.web.app,http://localhost:3000

# Hosted API durable storage. Leave blank for local file mode.
LIMEN_GITHUB_REPO=4444J99/limen
LIMEN_GITHUB_BRANCH=main
LIMEN_GITHUB_PATH=tasks.yaml
LIMEN_GITHUB_TOKEN=

# Dispatch commands.
LIMEN_JULES_BIN=jules
LIMEN_DISPATCH_CMD=agent-dispatch
LIMEN_DISPATCH_TIMEOUT_SEC=600

# Static dashboard build-time API URL.
NEXT_PUBLIC_API_URL=
