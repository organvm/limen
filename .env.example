LIMEN_TASKS=/limen/tasks.yaml
LIMEN_API_TOKEN=change-me
LIMEN_OWNER_TOKEN=
LIMEN_CLIENT_TOKEN=
LIMEN_CORS_ORIGINS=https://device-streaming-067d747a.web.app,http://localhost:3000

# Hosted API durable storage. Leave blank for local file mode.
LIMEN_GITHUB_REPO=4444J99/limen
LIMEN_GITHUB_BRANCH=main
LIMEN_GITHUB_PATH=tasks.yaml
LIMEN_GITHUB_TOKEN=

# Dispatch commands.
LIMEN_JULES_BIN=jules
LIMEN_DISPATCH_CMD=agent-dispatch
LIMEN_DISPATCH_TIMEOUT_SEC=600

# Warp/Oz (oz-by-warp GitHub App) — cloud agent lane.
# Set Warp API key to enable warp/oz dispatch via GitHub Actions:
#   1. Get a key from https://app.warp.dev — create an agent key for CI use.
#   2. Set WARP_API_KEY in your shell env AND add it as an Actions secret
#      (org-level or per-repo) so the GitHub Actions workflow can use it.
WARP_API_KEY=
# Repo hosting limen-warp-oz.yml workflow (default: organvm/limen).
# Change if you fork the workflow to another repo.
LIMEN_WARP_OZ_REPO=organvm/limen
# Workflow file name (default: limen-warp-oz.yml).
LIMEN_WARP_OZ_WORKFLOW=limen-warp-oz.yml

# Static dashboard build-time API URL.
NEXT_PUBLIC_API_URL=
