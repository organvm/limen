#!/usr/bin/python3
"""Fixed-owner shim into UMA's receipt-bound mail sender.

Preview never receives credentials. Apply delegates only to the Domus-installed,
root-owned UMA entrypoint; repository paths, Python modules, PATH, and caller
environment variables cannot select executable code.
"""

import os
import stat
import sys
from pathlib import Path


DOMUS_MAIL_ROOT = Path("/Library/Application Support/org.organvm.domus/limen/uma")
DOMUS_MAIL_DELEGATE = DOMUS_MAIL_ROOT / "bin" / "mail-send"
OWNER_CREDENTIALS = DOMUS_MAIL_ROOT / "credentials" / "mail.env"
OWNER_ATTEMPT_STORE = DOMUS_MAIL_ROOT / "state" / "mail-attempts"
OWNER_HOME = DOMUS_MAIL_ROOT / "home"
OWNER_TMPDIR = DOMUS_MAIL_ROOT / "tmp"
OWNER_WORKDIR = DOMUS_MAIL_ROOT / "run"
OWNER_PATH_ANCHOR = Path("/")
OWNER_UID = 0
SAFE_PATH = "/usr/bin:/bin:/usr/sbin:/sbin"
REFUSED_CALLER_FLAGS = (
    "--authorization-key-file",
    "--credentials-file",
    "--attempt-store",
)


class DelegateError(ValueError):
    """The fixed UMA delegate or invocation is not safe to execute."""


def _assert_owner_chain(path: Path, *, leaf_directory: bool = False) -> None:
    try:
        relative = path.relative_to(OWNER_PATH_ANCHOR)
    except ValueError as exc:
        raise DelegateError("UMA owner path escaped the fixed absolute authority anchor") from exc
    components = [
        OWNER_PATH_ANCHOR,
        *(
            OWNER_PATH_ANCHOR.joinpath(*relative.parts[:index])
            for index in range(1, len(relative.parts) + 1)
        ),
    ]
    for index, candidate in enumerate(components):
        try:
            metadata = candidate.lstat()
        except OSError as exc:
            raise DelegateError(f"UMA owner path is unavailable ({type(exc).__name__})") from exc
        is_leaf = index == len(components) - 1
        expected_directory = not is_leaf or leaf_directory
        if stat.S_ISLNK(metadata.st_mode):
            raise DelegateError("UMA owner path must not contain symlinks")
        if expected_directory and not stat.S_ISDIR(metadata.st_mode):
            raise DelegateError("UMA owner path component is not a directory")
        if not expected_directory and not stat.S_ISREG(metadata.st_mode):
            raise DelegateError("UMA delegate is not a regular file")
        if metadata.st_uid != OWNER_UID:
            raise DelegateError("UMA owner path is not owned by the Domus authority uid")
        if metadata.st_mode & (stat.S_IWGRP | stat.S_IWOTH):
            raise DelegateError("UMA owner path is group/world writable")


def _validate_delegate() -> None:
    _assert_owner_chain(DOMUS_MAIL_DELEGATE)
    metadata = DOMUS_MAIL_DELEGATE.stat()
    if metadata.st_nlink != 1:
        raise DelegateError("UMA delegate must have exactly one hard link")
    if not metadata.st_mode & stat.S_IXUSR:
        raise DelegateError("UMA delegate is not owner-executable")


def _flag_present(args, flag):
    return any(value == flag or value.startswith(flag + "=") for value in args)


def _validate_args(args):
    for flag in REFUSED_CALLER_FLAGS:
        if _flag_present(args, flag):
            raise DelegateError(f"caller-selected {flag} is refused")
    apply = _flag_present(args, "--apply")
    dry_run = _flag_present(args, "--dry-run")
    if apply and dry_run:
        raise DelegateError("--apply and --dry-run are mutually exclusive")
    if apply:
        for required in ("--attempt-id", "--authorization-receipt", "--authorization-signature"):
            if not _flag_present(args, required):
                raise DelegateError(f"apply requires {required}")
    return apply


def _credential_file(home: Path) -> Path:
    del home
    _assert_owner_chain(OWNER_CREDENTIALS)
    metadata = OWNER_CREDENTIALS.stat()
    if (
        not stat.S_ISREG(metadata.st_mode)
        or stat.S_ISLNK(metadata.st_mode)
        or metadata.st_nlink != 1
        or metadata.st_uid != OWNER_UID
        or stat.S_IMODE(metadata.st_mode) not in {0o400, 0o600}
    ):
        raise DelegateError("credential file must remain an owner-custodied mode-0400/0600 regular file")
    return OWNER_CREDENTIALS


def _validate_owner_directories(*, apply: bool) -> None:
    for directory in (OWNER_HOME, OWNER_TMPDIR, OWNER_WORKDIR):
        _assert_owner_chain(directory, leaf_directory=True)
    if apply:
        _assert_owner_chain(OWNER_ATTEMPT_STORE, leaf_directory=True)


def build_invocation(args, environ=None):
    del environ
    apply = _validate_args(args)
    _validate_delegate()
    _validate_owner_directories(apply=apply)
    delegate_args = [str(DOMUS_MAIL_DELEGATE)]
    if apply:
        delegate_args.extend(
            [
                "--credentials-file",
                str(_credential_file(OWNER_HOME)),
                "--attempt-store",
                str(OWNER_ATTEMPT_STORE),
            ]
        )
    elif not _flag_present(args, "--dry-run"):
        delegate_args.append("--dry-run")
    delegate_args.extend(args)
    clean_environment = {
        "HOME": str(OWNER_HOME),
        "TMPDIR": str(OWNER_TMPDIR),
        "PATH": SAFE_PATH,
        "PYTHONNOUSERSITE": "1",
        "PYTHONSAFEPATH": "1",
        "LC_ALL": "C",
    }
    return delegate_args, clean_environment


def main(argv=None):
    args = list(sys.argv[1:] if argv is None else argv)
    try:
        invocation, clean_environment = build_invocation(args)
    except DelegateError as exc:
        print(f"mail-send: REFUSED: {exc}", file=sys.stderr)
        return 4
    os.chdir(OWNER_WORKDIR)
    os.execve(str(DOMUS_MAIL_DELEGATE), invocation, clean_environment)
    return 127


if __name__ == "__main__":
    sys.exit(main())
