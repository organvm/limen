#!/usr/bin/env python3
"""Fail-closed Claude model-override chokepoint for the Limen fleet.

`scripts/heartbeat-loop.sh` prepends this directory onto the FLEET PATH, so every fleet-spawned
`claude` resolves HERE first. Interactive human shells never run heartbeat-loop.sh, so they never
see this shim — the human's own Opus is untouched by construction.

A bare launch stays on provider Auto. Every explicit ``--model`` or
``LIMEN_CLAUDE_MODEL`` override must pass the fresh live-catalog and execution-profile
validator before the real provider process is executed. Validator failure therefore
blocks only the override-bearing invocation; it never retunes or stops peer sessions.
"""

import os
import json
import pwd
import stat
import subprocess
import sys


def _shim_path() -> str:
    return os.path.realpath(__file__)


def _real_claude() -> str:
    """Locate the REAL claude binary — never this shim. LIMEN_REAL_CLAUDE (captured by
    heartbeat-loop.sh BEFORE it prepends the shim dir) wins; else scan PATH skipping our own
    directory and ourselves; else the canonical install path. Guarded against ever returning
    this script so an exec can never recurse into the shim."""
    me = _shim_path()
    pinned = os.environ.get("LIMEN_REAL_CLAUDE")
    if pinned and os.path.realpath(pinned) != me and os.path.isfile(pinned) and os.access(pinned, os.X_OK):
        return pinned
    self_dir = os.path.dirname(me)
    for d in os.environ.get("PATH", "").split(os.pathsep):
        if not d or os.path.realpath(d) == self_dir:
            continue
        cand = os.path.join(d, "claude")
        if os.path.realpath(cand) != me and os.path.isfile(cand) and os.access(cand, os.X_OK):
            return cand
    return os.path.expanduser("~/.local/bin/claude")


def _has_override(args) -> bool:
    return bool(
        os.environ.get("LIMEN_CLAUDE_MODEL")
        or os.environ.get("ANTHROPIC_MODEL")
        or os.environ.get("CLAUDE_MODEL")
        or any(arg == "--model" or arg.startswith("--model=") for arg in args)
    )


def _model_decision(args):
    """Return a decision from the sealed Domus-installed owner validator.

    ``LIMEN_ROOT`` is intentionally irrelevant here: dispatch rebinds it to the
    task worktree, and a task checkout must never supply its own authority code.
    """
    try:
        account_home = pwd.getpwuid(os.getuid()).pw_dir
        path = os.path.join(
            account_home,
            "Library",
            "Application Support",
            "org.organvm.limen",
            "authority",
            "runtime",
            "claude-model-validator",
        )
        metadata = os.lstat(path)
        if (
            stat.S_ISLNK(metadata.st_mode)
            or not stat.S_ISREG(metadata.st_mode)
            or metadata.st_mode & (stat.S_IWGRP | stat.S_IWOTH)
            or metadata.st_uid != 0
            or not metadata.st_mode & stat.S_IXUSR
        ):
            return None, "Claude owner validator is unsealed"
        run = subprocess.run(
            [path, "validate-claude-argv"],
            input=json.dumps(list(args), separators=(",", ":")),
            text=True,
            capture_output=True,
            timeout=20,
            check=False,
        )
        if run.returncode != 0:
            return None, (run.stderr or run.stdout).strip() or "Claude model selection validation failed"
        value = json.loads(run.stdout)
        if not isinstance(value, dict) or set(value) != {"model"}:
            return None, "Claude owner validator returned a malformed decision"
        model = value.get("model")
        if model is not None and (not isinstance(model, str) or not model.strip()):
            return None, "Claude owner validator returned a malformed decision"
        return model, None
    except FileNotFoundError:
        return None, "Claude owner validator is unprovisioned"
    except Exception as exc:
        return None, str(exc) or "Claude model selection validation failed"


def main() -> int:
    args = list(sys.argv[1:])
    real = _real_claude()
    model, blocked_reason = _model_decision(args)
    if blocked_reason and _has_override(args):
        print(f"BLOCKED: {blocked_reason}", file=sys.stderr)
        return 78
    if model:
        args = ["--model", model, *args]
    os.execv(real, [real, *args])
    return 0  # unreachable — execv replaces this process image


if __name__ == "__main__":
    raise SystemExit(main())
