# --- Sovereign licence mint configuration -----------------------------------
# Copy to `.env` (gitignored) and fill in. The mint runs without any of these
# (it just reports `configured:false` and refuses checkouts) so the CODE is done
# regardless; these values are the deploy/operate step, not a build step.

# The one self-custodied value: a Bitcoin address YOU control (any wallet, no
# account, no KYC). On-chain payments land here; the mint only ever READS the
# chain to confirm them — it never holds or moves your funds.
MINT_BTC_ADDRESS=

# Price of a Pro licence, in USD. Converted to sats at order time.
MINT_PRICE_USD=9

# Keyless public block explorer (Esplora API). mempool.space by default; swap
# for your own self-hosted mempool/Electrs instance for full sovereignty.
MINT_EXPLORER_BASE=https://mempool.space

# Confirmations required before a licence is minted (1 = first confirmation).
MINT_MIN_CONFIRMATIONS=1

# Optional static BTC/USD price. Leave empty to read the explorer's price oracle.
MINT_BTC_USD=

# Licence lifetime in days. 0 (default) = perpetual.
MINT_LICENSE_TTL_DAYS=0

# Minutes an unpaid order stays open before expiring.
MINT_ORDER_TTL_MINUTES=60

# Where the checkout page sends the buyer back with their minted licence.
# e.g. https://chatgpt.com/  -> buyer returns to ...?ce_license_key=<licence>
MINT_RETURN_URL_BASE=

# Signing key. Leave both unset to auto-generate + persist a key on first boot
# (recommended). MINT_KEY_FILE points at the gitignored JSON keyfile; or paste a
# private JWK directly into MINT_PRIVATE_JWK (e.g. a deploy secret).
MINT_KEY_FILE=.data/mint.key.json
MINT_PRIVATE_JWK=

# HTTP port.
PORT=8787
