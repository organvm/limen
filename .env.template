# Limen Configuration
# Copy to .env and adjust. All variables are optional except LIMEN_ROOT.

# Path to the limen directory containing tasks.yaml
LIMEN_ROOT="${HOME}/limen"

# Daily budget cap (default: 100)
LIMEN_BUDGET=100

# Which agent this session is (auto-detected if unset)
# Values: claude | gemini | jules | opencode | codex | copilot | goose
LIMEN_AGENT=

# Path to tasks.yaml (default: $LIMEN_ROOT/tasks.yaml)
LIMEN_TASKS=

# Git remote URL for sync
LIMEN_REPO=

# Dispatch command override (default: agent-dispatch)
LIMEN_DISPATCH_CMD=

# ── SaaS (Phase 3) ─────────────────────────────────────────────────────────

# Bearer token for API auth (leave empty for local-only)
LIMEN_API_TOKEN=

# FastAPI host/port (default: 0.0.0.0:8000)
LIMEN_API_HOST=0.0.0.0
LIMEN_API_PORT=8000
