{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'ROOT=\"${CODEX_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}\"; CLAUDE_PROJECT_DIR=\"$ROOT\" \"$ROOT/scripts/hooks/lint-edited-file.sh\"'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'ROOT=\"${CODEX_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}\"; CLAUDE_PROJECT_DIR=\"$ROOT\" \"$ROOT/scripts/hooks/session-orient.sh\"'"
          }
        ]
      }
    ]
  }
}
