{
  "name": "surface-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Public Audience Surfaces suite with unified webhook integration",
  "packageManager": "pnpm@10.34.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
