+    process.env.POSTGRES_USER = 'styx_admin';
+    process.env.POSTGRES_PASSWORD = 'styx_local_secret';
+    process.env.POSTGRES_DB = 'styx';
+    expect(() => resolveDatabaseUrl()).toThrow(
