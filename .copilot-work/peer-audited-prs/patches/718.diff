+# ============================================================================
+# Local one-command deploy defaults — `bash scripts/deploy.sh local`
+# ============================================================================
+# These values make `.config/docker/docker-compose.yml` boot the full Styx
+# stack (API + Web + PostgreSQL + Redis) on a fresh machine with NO hand
+# editing. They are fed to docker compose via `--env-file`.
+#
+# ⚠️  LOCAL DEVELOPMENT ONLY. The secrets below are well-known dev placeholders,
+#     NOT secrets. NEVER use this file for staging/production — those deploy via
+#     Render (`render.yaml` + `.github/workflows/deploy.yml`) with real secrets
+#     injected from the Render dashboard. To override any value locally, copy
+#     `.env.example` → `.env`; a present `.env` is layered on top of these
+#     defaults by the deploy script and wins.
+
+# --- Host-exposed ports (what you open in a browser) -------------------------
+STYX_DOCKER_API_PORT=3000
+STYX_DOCKER_WEB_PORT=3001
+STYX_DOCKER_POSTGRES_PORT=5432
+STYX_DOCKER_REDIS_PORT=6379
+
+# --- In-container ports ------------------------------------------------------
+STYX_DOCKER_API_CONTAINER_PORT=3000
+STYX_DOCKER_WEB_CONTAINER_PORT=3001
+
+# --- Runtime mode ------------------------------------------------------------
+STYX_DOCKER_API_NODE_ENV=production
+STYX_DOCKER_WEB_NODE_ENV=production
+
+# --- Base images -------------------------------------------------------------
+STYX_DOCKER_POSTGRES_IMAGE=postgres:16-alpine
+STYX_DOCKER_REDIS_IMAGE=redis:7-alpine
+
+# --- Datastore credentials (dev only) ----------------------------------------
+POSTGRES_USER=styx
+POSTGRES_PASSWORD=styx_local_dev
+POSTGRES_DB=styx
+POSTGRES_PORT=5432
+REDIS_PORT=6379
+
+# --- Service-to-service URLs (resolved on the compose network) ---------------
+STYX_DOCKER_DATABASE_URL=postgres://styx:styx_local_dev@styx-postgres:5432/styx
+STYX_DOCKER_REDIS_URL=redis://styx-redis:6379
+# Browser-facing API URL baked into the web build (must be reachable from the host).
+STYX_DOCKER_API_INTERNAL_URL=http://localhost:3000
+
+# --- Public URLs / CORS ------------------------------------------------------
+STYX_API_PUBLIC_URL=http://localhost:3000
+STYX_WEB_PUBLIC_URL=http://localhost:3001
+NEXT_PUBLIC_WEB_URL=http://localhost:3001
+CORS_ORIGINS=http://localhost:3001
+
+# --- Required app secrets (dev placeholders — see warning above) -------------
+# The 2026-05-26 hardening removed insecure fallbacks, so the API throws at
+# use-time if these are unset. Real values come from the Render dashboard in
+# deployed environments; these keep the local stack functional.
+JWT_SECRET=local-dev-jwt-secret-not-for-production-use-0001
+APP_SECRET=local-dev-app-secret-not-for-production-use-0002
+ANONYMIZE_SALT=local-dev-anonymize-salt-not-for-production-0003
+ZK_EXHAUST_SECRET=local-dev-zk-exhaust-secret-not-for-production-0004
+STYX_WEBHOOK_SECRET=local-dev-webhook-secret-not-for-production-0005
+INTERNAL_SERVICE_TOKEN=local-dev-internal-service-token-not-for-prod-0006
