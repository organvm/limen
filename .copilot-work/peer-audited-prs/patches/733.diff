+       FROM api_keys ak
+       JOIN users u ON u.id = ak.user_id
+       WHERE ak.key_id = $1`,
+      [parsed.keyId],
+    );
+
+    if (result.rows.length === 0) {
+      throw new UnauthorizedException('Invalid API key');
+    }
+
+    const row = result.rows[0];
