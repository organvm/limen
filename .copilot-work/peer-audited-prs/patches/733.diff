+export function parseApiKey(apiKey: string): { keyId: string; secret: string } | null { // allow-secret
+  const match = /^styx_live_([a-f0-9]{24})_([A-Za-z0-9_-]+)$/.exec(apiKey);
+  if (!match) {
+    return null;
+  }
+
+  return { keyId: match[1], secret: match[2] }; // allow-secret
