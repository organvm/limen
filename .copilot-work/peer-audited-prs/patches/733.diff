+    userId: string,
+    opts: { name?: string; expiresInDays?: number } = {},
+  ): Promise<IssuedApiKey> {
+    const expiresInDays = opts.expiresInDays ?? DEFAULT_API_KEY_EXPIRY_DAYS;
