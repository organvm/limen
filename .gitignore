__pycache__/
*.pyc
.venv/
.env
*.egg-info/
dist/
build/

# Firebase deployment cache
.firebase/
pr-status.json

# Local runtime secrets
.runtime/

# Build and tooling artifacts
node_modules/
**/node_modules
**/node_modules/
web/app/.next/
web/app/out/
.wrangler/
**/.wrangler/

# Generated private validation snapshots (rebuilt by generate:data)
web/app/.generated/

# Hosted public JSONs are generated at build time
web/app/public/

# Local conductor/report artifacts
.limen-reports/
obligations-ledger.json
.heal-probe-*.yaml

# TABVLARIVS record-keeper: the ticket inbox/archive/rejected is runtime event state (one file per
# unit of work, high churn). The board (tasks.yaml) is the committed projection; tickets are not.
logs/tickets/
logs/closeout-fast.json
logs/closeout-fast.md

# Next.js route source — protect from machine-global 'public/' ignore rules
!web/app/app/public/
env/
container/backup/
container/state/
*.premigrate
.limen.env
.limen-private/
MASTER-PLAN.md
# git worktree dirs (isolation checkouts — never tracked)
.worktrees/
.claude/worktrees/
# nested vendored clones (their own repos — archived independently)
domus-genoma/
# build artifacts
*.tsbuildinfo
# inbound positioning: internal price-anchor sheets are regenerable and must never sit as a
# standing file in a public repo (scripts/generate-positioning.py rebuilds them from seeds).
docs/positioning/*.internal.md
# studium convergence logs are GENERATED and captured local worktree home paths (PII);
# never track them in this public repo (studium re-derives them locally each run).
studium/_converged/converge-log.jsonl
.codex/worktrees/
docs/prompt-atom-ledger.json
# cross-vendor raw extraction packets (PII-risk; generated locally, fed to synthesis pass)
logs/insight-cross-vendor/
# sensitive publication-judgment rationale (shallow-merged into repo_overrides at load; arca-sealed)
institutio/github/estate.private.yaml

# Copilot coding-agent lane scratch — the --yolo issue-backlog lane dumps its
# working state (clones, peer-audit generators + JSON) into the checkout root
# instead of an isolated dir. These are generated artifacts, never repo source;
# ignore so they stop surfacing as thousands of "uncommitted changes". The lane's
# cwd-isolation fix is tracked separately (see the copilot-live-checkout censor issue).
.copilot-work/
scratch/
issue_backlog_work/
peer-audited--*/
peer_audit_comments_*.json
peer_audited_issues.json
peer_audited_issues_summary.txt
peer_audited_comment_map.json
issue_backlog_peer_audited_*.json
issue_audit_data.json
issue_comment_plan.json
build_peer_audited_comments.py
generate_peer_audit_comments.py
